# Dominio público para sitemap/robots
SITE_URL=https://tu-dominio.com

# Supabase (solo para generación de sitemap en build)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_supabase_anon_key
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key
SUPABASE_SECRET_API_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key

# Canary de migración Next para /articulos (en app actual)
NEXT_CANARY_ENABLED=false
NEXT_CANARY_PERCENT=10
NEXT_CANARY_ORIGIN=https://next.tu-dominio.com

# Refresh inmediato de sitemap al publicar (opcional; usa uno)
VITE_SITEMAP_WEBHOOK_URL=
VITE_SITEMAP_FUNCTION_NAME=

# Optimización de imágenes internas en servidor (Supabase Edge Function)
VITE_IMAGE_OPTIMIZER_FUNCTION_NAME=image-optimize
